# LLM Configuration — choose one and set the corresponding API key
# For Google Gemini:
GEMINI_API_KEY=your_google_api_key_here

# For OpenAI:
# OPENAI_API_KEY=your_openai_api_key_here

# For Serper (internet search tool):
SERPER_API_KEY=your_serper_api_key_here

# Redis URL for Celery queue worker (optional, for async mode):
# REDIS_URL=redis://localhost:6379/0

# Database URL (optional, defaults to sqlite:///./financial_analyzer.db):
# DATABASE_URL=sqlite:///./financial_analyzer.db
